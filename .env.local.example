# 로컬 개발은 이 파일을 .env.local로, Docker Compose 배포는 .env로 복사하세요.
# 실제 값이 든 .env/.env.local은 커밋하지 않습니다.

# --- 로그인·운영자 계정 (필수) ---
# 운영에서는 반드시 새 값을 생성하세요: openssl rand -base64 32
BETTER_AUTH_SECRET=

# 로컬은 아래 주소, VPS는 실제 HTTPS 공개 주소(예: https://ijik.example.com)
BETTER_AUTH_URL=http://localhost:3000

# 서버가 처음 시작될 때 미리 만들 운영자 계정. 이메일 자체는 비밀값이 아닙니다.
OPERATOR_EMAIL=
OPERATOR_NAME=운영자

# 운영자 비밀번호는 둘 중 하나만 사용하세요. 12자 이상이어야 합니다.
# 파일 경로 방식이 우선이며 VPS에서는 권한 600인 파일/Docker secret을 권장합니다.
OPERATOR_PASSWORD_FILE=
# 로컬 개발 편의용 fallback. 최초 생성 후 값을 지우고 앱을 다시 시작하세요.
OPERATOR_BOOTSTRAP_PASSWORD=

# 정확히 open일 때만 /signup과 가입 API가 열립니다. 기본은 안전하게 closed입니다.
# 운영자 생성·기존 데이터 귀속을 확인한 뒤 필요한 기간에만 open으로 바꾸세요.
SIGNUP_MODE=closed

# --- 옵션 A: 로컬 LLM (기본값, 무료) ---
# Ollama 설치/실행: brew install ollama && brew services start ollama
# 모델 다운로드:    ollama pull qwen3:8b
# 다른 모델을 쓰려면 주석 해제 (한국어 자연스러움 우선이면 exaone3.5:7.8b 추천)
# OLLAMA_MODEL=qwen3:8b
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_TIMEOUT_MS=1800000

# --- 옵션 B: Claude API (유료, 품질 우선) ---
# 키를 넣으면 자동으로 Claude를 사용합니다. 키 발급: https://platform.claude.com/
# ANTHROPIC_API_KEY=sk-ant-...
