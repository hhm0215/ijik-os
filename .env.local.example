# 로컬 개발은 이 파일을 .env.local로, Docker Compose 배포는 .env로 복사하세요.
# 실제 값이 든 .env/.env.local은 커밋하지 않습니다.

# --- 소유자 로그인 (필수) ---
# 운영에서는 반드시 새 값을 생성하세요: openssl rand -base64 32
BETTER_AUTH_SECRET=

# 로컬은 아래 주소, VPS는 실제 HTTPS 공개 주소(예: https://ijik.example.com)
BETTER_AUTH_URL=http://localhost:3000

# 최초이자 유일한 소유자 계정 이메일. 이메일 자체는 비밀값이 아닙니다.
OWNER_EMAIL=

# /setup에서 한 번만 쓰는 초기 설정 코드. 최소 24자, 권장 생성 명령: openssl rand -base64 32
# 소유자 생성이 끝나면 값을 비우고 앱 컨테이너를 다시 생성하세요.
OWNER_SETUP_TOKEN=

# --- 옵션 A: 로컬 LLM (기본값, 무료) ---
# Ollama 설치/실행: brew install ollama && brew services start ollama
# 모델 다운로드:    ollama pull qwen3:8b
# 다른 모델을 쓰려면 주석 해제 (한국어 자연스러움 우선이면 exaone3.5:7.8b 추천)
# OLLAMA_MODEL=qwen3:8b
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_TIMEOUT_MS=1800000

# --- 옵션 B: Claude API (유료, 품질 우선) ---
# 키를 넣으면 자동으로 Claude를 사용합니다. 키 발급: https://platform.claude.com/
# ANTHROPIC_API_KEY=sk-ant-...
